# Copy to .env.local for local dev (never commit real values).
# In production these are set as Vercel Environment Variables.

# ── Client (Vite) — exposed to the browser, injected at build time ───────────
# Added in T2 (Supabase). Not required for the T1 demo.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Server only (Vercel functions) — NEVER prefix these with VITE_ ───────────
# T1 (the reading engine) needs only ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=

# Reading gate. Leave unset/false for T1 so the free first reading works with no
# login. T2 sets this to "true" once the Supabase JWT + credit/subscription gate
# is wired into /api/consult.
GATING_ENABLED=false

# Added in T2/T3 (Supabase service role + Stripe). Not required for the T1 demo.
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_FIVEPACK=
STRIPE_PRICE_SUB=
