# Copy to .env.local for local dev (never commit real values).
# In production these are set as Vercel Environment Variables.

# ── Client (Vite) — exposed to the browser, injected at build time ───────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Server only (Vercel functions) — NEVER prefix these with VITE_ ───────────
ANTHROPIC_API_KEY=

# Bypasses RLS. Server only, always.
SUPABASE_SERVICE_ROLE_KEY=

# The reading gate in /api/consult.
#   unset/false -> every reading is allowed (demo mode, no login needed)
#   true        -> verify the Supabase JWT, then: active subscription -> allow;
#                  else spend a credit; else use the free reading; else 402.
# Turn this on once supabase/schema.sql has been run.
GATING_ENABLED=true

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
# From `stripe listen` locally, or the endpoint's signing secret in the
# Stripe dashboard once /api/stripe-webhook is registered.
STRIPE_WEBHOOK_SECRET=
# Price IDs (price_...), not product IDs.
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_FIVEPACK=
STRIPE_PRICE_SUB=
